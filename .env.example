# Copy this to .env for local dev, or paste values into Render's "Environment" tab.

# Required — get from https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-long-random-hex-string

# Optional — defaults to jobhunter.db in working directory
DB_PATH=jobhunter.db

# Optional — Render sets this automatically
PORT=5000
